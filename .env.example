# =============================================================
# Python Unit Test Generator — Frontend Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Nuxt automatically maps these to runtimeConfig using the
# NUXT_ prefix, e.g. NUXT_AUTH_USERNAME → runtimeConfig.authUsername

# ---- Authentication (server-side only) ----------------------
# Admin credentials for the login page
NUXT_AUTH_USERNAME=admin
NUXT_AUTH_PASSWORD=changeme_strong_password

# JWT signing secret — use a random string of at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
NUXT_JWT_SECRET=replace_with_random_64_char_secret_here_never_commit_this

# ---- Backend AI Service -------------------------------------
# URL of the Python backend that runs the LLM (see docs/backend-api.md)
# Leave empty OR set to "mock" to enable the built-in mock mode:
#   → no real backend needed
#   → /api/generate returns random pre-written test samples (~1.4s simulated delay)
#   → a yellow MOCK badge appears in the UI header
#
# Mock mode (default when NUXT_BACKEND_URL is unset):
# NUXT_BACKEND_URL=mock
#
# Real backend:
NUXT_BACKEND_URL=http://localhost:8000
